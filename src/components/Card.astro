---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="rounded-xl border bg-white text-zinc-900 shadow-sm dark:border-zinc-800 dark:bg-white/5 dark:text-zinc-100 p-1">
  <div class="flex items-center gap-3 px-2 pt-3 pb-4">
    <div class="flex size-7 shrink-0 items-center justify-center rounded-lg border bg-zinc-100 text-zinc-500 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-400">
      <slot name="icon" />
    </div>
    <h2 class="text-lg leading-none font-semibold tracking-tight">{title}</h2>
    <div class="gap-2 ml-auto flex items-center">
      <slot name="action" />
    </div>
  </div>
  <div class="px-1 pb-1">
    <slot />
  </div>
</div>
